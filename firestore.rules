rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, max length 50) - The name of the user
    //   - caption: string (required, max length 500) - The caption for the picture
    //   - imageUrl: string (required, valid URL) - The URL of the picture
    //   - createdAt: timestamp (required, immutable) - Creation time
    //   - uid: string (required, immutable) - The UID of the uploader
    //   - visibility: string (required) - 'public' or 'private'
    //   - likes: list (optional) - Array of UIDs
    //
    // Collection: posts/{postId}/comments
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required)
    //   - uid: string (required)
    //   - name: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //   - replyTo: string (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string
    //   - name: string
    //   - email: string
    //   - balance: number
    //
    // Collection: withdrawals
    // Document ID: auto-generated
    // Fields:
    //   - uid: string
    //   - amount: number
    //   - method: string
    //   - accountNumber: string
    //   - status: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (('email' in request.auth.token && request.auth.token.email.lower() == "sabihait20@gmail.com") ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Domain Validators
    function isValidPost(data) {
      return hasOnlyAllowedFields(['name', 'caption', 'imageUrl', 'createdAt', 'uid', 'visibility', 'likes', 'photoURL', 'views', 'username']) &&
             hasRequiredFields(['name', 'caption', 'createdAt', 'uid', 'visibility']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('caption', 0, 1000) &&
             (!('imageUrl' in data) || data.imageUrl == '' || isValidUrl(data.imageUrl)) &&
             data.createdAt is timestamp &&
             data.uid is string &&
             data.uid.size() > 0 && data.uid.size() < 128 &&
             (data.visibility == 'public' || data.visibility == 'private') &&
             (!('likes' in data) || data.likes is list) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('views' in data) || data.views is number) &&
             (!('username' in data) || data.username is string);
    }

    function isValidComment(data) {
      return hasOnlyAllowedFields(['text', 'uid', 'name', 'photoURL', 'createdAt', 'replyTo', 'username']) &&
             hasRequiredFields(['text', 'uid', 'name', 'createdAt']) &&
             validStringLength('text', 1, 2000) &&
             validStringLength('name', 1, 100) &&
             data.uid is string &&
             data.createdAt is timestamp &&
             (!('username' in data) || data.username is string);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'email', 'balance', 'photoURL', 'username', 'updatedAt', 'fcmToken', 'role', 'savedPosts', 'isVerified']) &&
             hasRequiredFields(['uid']) &&
             data.uid is string &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('email' in data) || data.email is string) &&
             (!('balance' in data) || data.balance is number) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('username' in data) || (data.username is string && data.username.matches("^[a-zA-Z0-9_]{3,20}$"))) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('fcmToken' in data) || data.fcmToken is string) &&
             (!('role' in data) || data.role in ['admin', 'client']) &&
             (!('savedPosts' in data) || data.savedPosts is list) &&
             (!('isVerified' in data) || data.isVerified is bool);
    }

    function isValidWithdrawal(data) {
      return hasOnlyAllowedFields(['uid', 'amount', 'method', 'accountNumber', 'status', 'createdAt', 'adminEmail', 'userEmail']) &&
             hasRequiredFields(['uid', 'amount', 'method', 'accountNumber', 'status', 'createdAt']) &&
             data.uid is string &&
             data.amount is number &&
             data.amount >= 100 &&
             (data.method == 'bkash' || data.method == 'nagad' || data.method == 'rocket') &&
             data.accountNumber is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is timestamp &&
             (!('adminEmail' in data) || data.adminEmail == 'sabihait20@gmail.com') &&
             (!('userEmail' in data) || data.userEmail is string);
    }

    function isValidUserPublic(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'photoURL', 'username', 'balance', 'isVerified']) &&
             hasRequiredFields(['uid', 'name']) &&
             data.uid is string &&
             data.name is string &&
             validStringLength('name', 1, 100) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('username' in data) || (data.username is string && data.username.matches("^[a-zA-Z0-9_]{3,20}$"))) &&
             (!('balance' in data) || data.balance is number) &&
             (!('isVerified' in data) || data.isVerified is bool);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['text', 'senderId', 'createdAt', 'status']) &&
             hasRequiredFields(['text', 'senderId', 'createdAt']) &&
             data.text is string &&
             validStringLength('text', 1, 1000) &&
             data.senderId is string &&
             data.createdAt is timestamp &&
             (!('status' in data) || data.status in ['sent', 'read']);
    }

    function isValidFollower(data) {
      return hasOnlyAllowedFields(['followerId', 'followingId', 'createdAt']) &&
             hasRequiredFields(['followerId', 'followingId', 'createdAt']) &&
             data.followerId is string &&
             data.followingId is string &&
             data.createdAt is timestamp;
    }

    function isValidStory(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'photoURL', 'imageUrl', 'createdAt', 'expiresAt']) &&
             hasRequiredFields(['uid', 'name', 'imageUrl', 'createdAt', 'expiresAt']) &&
             data.uid is string &&
             data.name is string &&
             data.imageUrl is string &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp &&
             (!('photoURL' in data) || data.photoURL is string);
    }

    function isValidAdBanner(data) {
      return hasOnlyAllowedFields(['imageUrl', 'linkUrl', 'active', 'createdAt']) &&
             hasRequiredFields(['imageUrl', 'linkUrl', 'active', 'createdAt']) &&
             isValidUrl(data.imageUrl) &&
             isValidUrl(data.linkUrl) &&
             data.active is bool &&
             data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return hasOnlyAllowedFields(['recipientId', 'senderId', 'senderName', 'senderPhotoURL', 'type', 'postId', 'createdAt', 'read']) &&
             hasRequiredFields(['recipientId', 'senderId', 'senderName', 'type', 'createdAt', 'read']) &&
             data.recipientId is string &&
             data.senderId is string &&
             data.senderName is string &&
             data.type in ['like', 'comment', 'follow'] &&
             data.createdAt is timestamp &&
             data.read is bool &&
             (!('senderPhotoURL' in data) || data.senderPhotoURL is string) &&
             (!('postId' in data) || data.postId is string);
    }

    function isValidGlobalNotification(data) {
      return hasOnlyAllowedFields(['title', 'body', 'createdAt', 'senderId']) &&
             hasRequiredFields(['title', 'body', 'createdAt', 'senderId']) &&
             validStringLength('title', 1, 100) &&
             validStringLength('body', 1, 1000) &&
             data.createdAt is timestamp &&
             data.senderId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /global_notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin() && isValidGlobalNotification(request.resource.data);
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    isValidStory(request.resource.data) && 
                    uidUnchanged() &&
                    request.resource.data.createdAt == request.time;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
      allow create: if isAuthenticated() && 
                    isValidNotification(request.resource.data) && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.createdAt == request.time;
      allow update: if isAuthenticated() && 
                    request.auth.uid == resource.data.recipientId &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                    request.resource.data.read == true;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
    }

    match /followers/{followerId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    isValidFollower(request.resource.data) && 
                    request.resource.data.followerId == request.auth.uid &&
                    request.resource.data.createdAt == request.time;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }

    match /users_public/{userId} {
      allow read: if true;
      allow write: if (isOwner(userId) && isValidUserPublic(request.resource.data)) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && chatId.matches('.*' + request.auth.uid + '.*');
        allow create: if isAuthenticated() && 
                      chatId.matches('.*' + request.auth.uid + '.*') &&
                      isValidMessage(request.resource.data) &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.createdAt == request.time;
        allow update: if isAuthenticated() && 
                      chatId.matches('.*' + request.auth.uid + '.*') &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status == 'read';
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidUnchanged() && 
                    (!('role' in request.resource.data) || 
                     request.resource.data.role == 'client' || 
                     ('email' in request.auth.token && request.auth.token.email.lower() == "sabihait20@gmail.com"));
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) && 
                    uidNotModified() && 
                    (isAdmin() || (request.resource.data.role == resource.data.role || !('role' in resource.data)));
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && 
                    isValidWithdrawal(request.resource.data) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'adminEmail']);
    }

    match /ad_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.uid == request.auth.uid && 
                    username.matches("^[a-zA-Z0-9_]{3,20}$") &&
                    !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isValidPost(request.resource.data) && 
                    uidUnchanged() &&
                    request.resource.data.createdAt == request.time;
                    
      allow update: if (isDocOwner() && 
                        isValidPost(request.resource.data) && 
                        uidNotModified() &&
                        request.resource.data.createdAt == resource.data.createdAt) ||
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'views'])) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
                    
      allow delete: if isDocOwner() || isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                      isValidComment(request.resource.data) &&
                      uidUnchanged() &&
                      request.resource.data.createdAt == request.time;
        allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }
  }
}
