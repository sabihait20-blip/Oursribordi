{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A picture post uploaded by a user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the user who uploaded the picture."
        },
        "caption": {
          "type": "string",
          "description": "The caption for the picture."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the uploaded picture on ImgBB."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the post was created."
        },
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the user who uploaded the picture."
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"],
          "description": "Whether the post is public or private."
        },
        "likes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of user UIDs who liked the post."
        }
      },
      "required": ["name", "caption", "imageUrl", "createdAt", "uid", "visibility"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text content of the comment."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who commented."
        },
        "name": {
          "type": "string",
          "description": "The display name of the user."
        },
        "photoURL": {
          "type": "string",
          "description": "The profile picture URL of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the comment was created."
        },
        "replyTo": {
          "type": "string",
          "description": "The ID of the parent comment, if this is a reply."
        }
      },
      "required": ["text", "uid", "name", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and balance.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "balance": {
          "type": "number",
          "description": "User's current balance in BDT."
        },
        "photoURL": {
          "type": "string"
        },
        "username": {
          "type": "string",
          "description": "Unique username for custom profile URL."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "fcmToken": {
          "type": "string",
          "description": "Firebase Cloud Messaging token for push notifications."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "client"]
        },
        "savedPosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "isVerified": {
          "type": "boolean"
        }
      },
      "required": ["uid"]
    },
    "UserPublic": {
      "title": "UserPublic",
      "description": "Public user profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "username": {
          "type": "string",
          "description": "Unique username for custom profile URL."
        },
        "balance": {
          "type": "number"
        },
        "isVerified": {
          "type": "boolean"
        }
      },
      "required": ["uid", "name"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation between two users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lastMessage": {
          "type": "string"
        },
        "lastMessageTime": {
          "type": "string",
          "format": "date-time"
        },
        "lastSenderId": {
          "type": "string"
        },
        "isRead": {
          "type": "boolean"
        }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat conversation.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["sent", "read"]
        }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "method": {
          "type": "string",
          "enum": ["bkash", "nagad", "rocket"]
        },
        "accountNumber": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "adminEmail": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        }
      },
      "required": ["uid", "amount", "method", "accountNumber", "status", "createdAt"]
    },
    "Follower": {
      "title": "Follower",
      "description": "A follower relationship between two users.",
      "type": "object",
      "properties": {
        "followerId": {
          "type": "string",
          "description": "The UID of the user who is following."
        },
        "followingId": {
          "type": "string",
          "description": "The UID of the user being followed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "AdBanner": {
      "title": "AdBanner",
      "description": "A banner advertisement displayed in the slideshow.",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "linkUrl": {
          "type": "string",
          "format": "uri"
        },
        "active": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["imageUrl", "linkUrl", "active", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": {
        "$ref": "#/entities/Post"
      },
      "description": "A collection of picture posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": {
        "$ref": "#/entities/Comment"
      },
      "description": "Comments for a specific post."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles and balances."
    },
    "/users_public/{userId}": {
      "schema": {
        "$ref": "#/entities/UserPublic"
      },
      "description": "Public user profile information."
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Chat conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Messages within a chat."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": {
        "$ref": "#/entities/Withdrawal"
      },
      "description": "Withdrawal requests."
    },
    "/followers/{followerDocId}": {
      "schema": {
        "$ref": "#/entities/Follower"
      },
      "description": "Follower relationships."
    },
    "/ad_banners/{bannerId}": {
      "schema": {
        "$ref": "#/entities/AdBanner"
      },
      "description": "Banner advertisements for the slideshow."
    },
    "/usernames/{username}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string"
          }
        },
        "required": ["uid"]
      },
      "description": "Mapping of unique usernames to user UIDs."
    }
  }
}
